{
  "api": {
    "base_url": "https://pokeapi.co/api/v2",
    "endpoints": ["pokemon", "type", "ability", "move"],
    "limit": 151
  },
  "unity_catalog": {
    "catalog": "pokelakehouse",
    "bronze_schema": "bronze",
    "silver_schema": "silver",
